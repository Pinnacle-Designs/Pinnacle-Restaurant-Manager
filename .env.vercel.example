# Copy to .env.vercel (gitignored), fill in real secrets, then: npm run vercel:env:push
# Do NOT commit .env.vercel.

# --- Required for production ---
AUTH_SECRET=
NEXT_PUBLIC_APP_URL=https://pinnacle-resturant-manager.vercel.app
DATABASE_URL=file:prisma/deploy.sqlite
# SQLite on Vercel (demo / preview only — use Postgres for real production)
ALLOW_SQLITE_PRODUCTION=true
SEED_DEMO_DATA=true

# --- Private sales deck (unlisted URL; not on marketing site) ---
# Share: https://your-app.vercel.app/sales-deck?key=<this-value>
SALES_DECK_ACCESS_KEY=

# --- Billing (fill when Stripe is live) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=
STRIPE_CONNECT_CLIENT_ID=
PLAN_TRIAL_DAYS=14
PLAN_BILLING_OPTIONAL=true
SUPPORT_EMAIL=support@pinnacle.app

# --- Square POS (optional) ---
SQUARE_APPLICATION_ID=
SQUARE_APPLICATION_SECRET=
SQUARE_ENVIRONMENT=production

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=
SMTP_FROM=Your Company <noreply@example.com>
SMTP_SECURE=false
# Optional — override default signature (use | between lines)
SMTP_EMAIL_SIGNATURE=Your Name|Your Company|support@example.com|https://your-app.vercel.app

# --- Twilio hiring SMS (optional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Rate limiting across Vercel instances (recommended) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Admin ---
PLATFORM_ADMIN_EMAILS=

# --- App store links (optional) ---
NEXT_PUBLIC_APP_STORE_URL=
NEXT_PUBLIC_PLAY_STORE_URL=

# --- AI (optional) ---
OPENAI_API_KEY=
